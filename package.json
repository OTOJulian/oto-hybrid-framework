{
  "name": "oto",
  "version": "0.4.1",
  "description": "Hybrid AI-CLI framework: GSD planning + Superpowers skills under /oto-* across Claude/Codex/Gemini",
  "engines": { "node": ">=22.0.0" },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.84",
    "ws": "^8.20.0"
  },
  "bin": {
    "oto": "bin/install.js",
    "oto-sdk": "bin/oto-sdk.js"
  },
  "files": [
    "bin/",
    "oto/",
    "hooks/",
    "scripts/rebrand/",
    "scripts/sync-upstream/",
    "scripts/build-hooks.js",
    "sdk/dist/",
    "sdk/package.json",
    "sdk/prompts/",
    "rename-map.json",
    "schema/",
    "package.json",
    "README.md",
    "LICENSE",
    "THIRD-PARTY-LICENSES.md"
  ],
  "scripts": {
    "postinstall": "node scripts/build-hooks.js",
    "test": "node --test --test-concurrency=4 tests/*.test.cjs",
    "rebrand": "node scripts/rebrand.cjs --apply --force",
    "rebrand:dry-run": "node scripts/rebrand.cjs --dry-run",
    "rebrand:roundtrip": "node scripts/rebrand.cjs --verify-roundtrip"
  },
  "repository": { "type": "git", "url": "git+https://github.com/OTOJulian/oto-hybrid-framework.git" },
  "license": "MIT",
  "author": "Julian Isaac"
}
